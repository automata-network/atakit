{
    "workloads": [
        {
            "name": "secure-signer",
            "version": "v0.0.1",
            "image": "automata-linux:v0.1.0",
            "docker_compose": "./container/docker-compose.yml"
        }
    ],
    "disks": [
        {
            "name": "secure-signer-data",
            "size": "10GB"
        },
        {
            "name": "secure-signer-data2",
            "size": "11GB"
        }
    ],
    "deployment": {
        "secure-signer-tdx": {
            "workload": "secure-signer",
            "platforms": {
                "gcp": { "vmtype": "c3-standard-4" }
            }
        }
    }
}